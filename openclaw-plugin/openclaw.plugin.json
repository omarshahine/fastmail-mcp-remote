{
  "id": "fastmail-cli",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "cliCommand": {
        "type": "string",
        "default": "fastmail",
        "description": "Path or alias for the fastmail CLI (default: 'fastmail')"
      },
      "autoDiscover": {
        "type": "boolean",
        "default": true,
        "description": "Auto-discover disabled categories from server at startup (requires authenticated CLI)"
      },
      "disabledCategories": {
        "type": "array",
        "items": {
          "type": "string",
          "enum": [
            "EMAIL_READ",
            "CONTACTS",
            "CALENDAR_READ",
            "CALENDAR_WRITE",
            "INBOX_MANAGE",
            "DRAFT",
            "REPLY",
            "SEND",
            "META"
          ]
        },
        "default": [],
        "description": "Tool categories to hide (must match server permissions config)"
      }
    }
  },
  "skills": [
    "./skills"
  ]
}
