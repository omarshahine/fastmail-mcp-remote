---
import { execFileSync } from 'node:child_process';

let version = '';
try {
  version = execFileSync('git', ['describe', '--tags', '--abbrev=0'], { encoding: 'utf-8' }).trim();
} catch {
  // Shallow clone (e.g. Cloudflare Pages) — fall back to GitHub API
  try {
    const res = await fetch('https://api.github.com/repos/omarshahine/fastmail-mcp-remote/releases/latest');
    if (res.ok) {
      const data = await res.json();
      version = data.tag_name || '';
    }
  } catch { /* no version badge */ }
}

const navLinks = [
  { href: '#features', label: 'Features' },
  { href: '#architecture', label: 'How It Works', highlight: true },
  { href: '#tools', label: 'Tools' },
  { href: '#quickstart', label: 'Quick Start' },
];
---

<nav class="fixed top-4 left-1/2 -translate-x-1/2 z-50 w-[calc(100%-2rem)] max-w-5xl">
  <div class="backdrop-blur-xl bg-background/60 border border-border rounded-2xl px-4 sm:px-6 py-3">
    <div class="flex items-center justify-between">
      <!-- Logo + Version -->
      <a href={`${import.meta.env.BASE_URL}`} class="flex items-center gap-2.5 shrink-0">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="w-5 h-5 text-accent"
        >
          <rect width="20" height="16" x="2" y="4" rx="2"></rect>
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
        </svg>
        <span class="font-semibold text-foreground text-sm sm:text-base">Fastmail Remote</span>
        {version && (
          <span class="hidden sm:inline-flex bg-accent/10 text-accent text-xs font-mono px-2 py-0.5 rounded-md border border-accent/20">
            {version}
          </span>
        )}
      </a>

      <!-- Desktop Nav Links -->
      <div class="hidden md:flex items-center gap-1">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              'px-3 py-1.5 rounded-lg text-sm transition-all',
              link.highlight
                ? 'bg-accent/10 text-accent border border-accent/20 hover:bg-accent/20'
                : 'text-muted hover:text-foreground hover:bg-card',
            ]}
          >
            {link.label}
          </a>
        ))}

        <!-- Star on GitHub -->
        <a
          href="https://github.com/omarshahine/fastmail-mcp-remote"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm text-muted hover:text-foreground hover:bg-card transition-all ml-1"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"></path>
          </svg>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5 text-yellow-400">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path>
          </svg>
          Star
          <span id="github-stars" class="bg-card border border-border text-xs font-mono px-1.5 py-0.5 rounded-md"></span>
        </a>

        <!-- Sponsor -->
        <a
          href="https://github.com/sponsors/omarshahine"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm text-pink-400 hover:text-pink-300 hover:bg-pink-500/10 transition-all"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4">
            <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"></path>
          </svg>
          Sponsor
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        type="button"
        class="md:hidden text-muted hover:text-foreground transition-colors p-1"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5">
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden md:hidden mt-3 pt-3 border-t border-border transition-all duration-200 ease-in-out">
      <div class="flex flex-col gap-1">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              'px-3 py-2 rounded-lg text-sm transition-all mobile-link',
              link.highlight
                ? 'bg-accent/10 text-accent'
                : 'text-muted hover:text-foreground hover:bg-card',
            ]}
          >
            {link.label}
          </a>
        ))}
        <a
          href="https://github.com/omarshahine/fastmail-mcp-remote"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-1.5 px-3 py-2 rounded-lg text-sm text-muted hover:text-foreground hover:bg-card transition-all mobile-link"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"></path>
          </svg>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5 text-yellow-400">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path>
          </svg>
          Star on GitHub
        </a>
        <a
          href="https://github.com/sponsors/omarshahine"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-1.5 px-3 py-2 rounded-lg text-sm text-pink-400 hover:text-pink-300 hover:bg-pink-500/10 transition-all mobile-link"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4">
            <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"></path>
          </svg>
          Sponsor
        </a>
      </div>
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');

  function closeMenu() {
    menu?.classList.add('hidden');
    btn?.setAttribute('aria-expanded', 'false');
  }

  function toggleMenu() {
    const isHidden = menu?.classList.toggle('hidden');
    btn?.setAttribute('aria-expanded', String(!isHidden));
  }

  btn?.addEventListener('click', toggleMenu);

  // Close mobile menu on link click
  document.querySelectorAll('.mobile-link').forEach((link) => {
    link.addEventListener('click', closeMenu);
  });

  // Close mobile menu on click outside
  document.addEventListener('click', (e) => {
    const nav = document.querySelector('nav');
    if (nav && !nav.contains(e.target as Node)) {
      closeMenu();
    }
  });

  // Close on Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !menu?.classList.contains('hidden')) {
      closeMenu();
      btn?.focus();
    }
  });

  // Fetch GitHub star count
  async function fetchStarCount() {
    const el = document.getElementById('github-stars');
    if (!el) return;
    try {
      const res = await fetch('https://api.github.com/repos/omarshahine/fastmail-mcp-remote');
      if (res.ok) {
        const data = await res.json();
        const count = data.stargazers_count;
        el.textContent = count >= 1000 ? `${(count / 1000).toFixed(1)}k` : String(count);
      }
    } catch { /* silently fail */ }
  }
  fetchStarCount();

</script>
